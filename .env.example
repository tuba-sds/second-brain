# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must never be committed.
#
# Compliance posture: self-hosted only. No S3/AWS variables belong in this
# file (files are stored on local disk via FILE_STORAGE_PATH), and no hosted
# embeddings API keys belong here (embeddings are local via Ollama only).

# --- Database -------------------------------------------------------------
# Host tooling (e.g. `npx prisma migrate dev` run on your machine) uses
# localhost. Inside docker compose, web/worker override this to use the
# `postgres` service hostname automatically.
DATABASE_URL=postgresql://secondbrain:secondbrain@localhost:5432/secondbrain

# --- Auth (Google OAuth via NextAuth / Auth.js) -----------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-a-random-secret

# These come from a Google Cloud OAuth 2.0 client
# (Google Cloud Console > APIs & Services > Credentials > OAuth client ID,
# authorized redirect URI: http://localhost:3000/api/auth/callback/google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM (Claude via the Anthropic API) -------------------------------------
# This must be a real Anthropic API key from the company's Anthropic account
# (console.anthropic.com). It is separate from any Claude Code CLI
# subscription — a Claude Code login does NOT provide an API key.
ANTHROPIC_API_KEY=
# Verify this model id against current Anthropic API docs before deploying.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Embeddings (local via Ollama only — no hosted embeddings APIs) ---------
# Inside docker compose this is overridden to http://ollama:11434.
# Use http://localhost:11434 when running the app directly on your machine.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- File storage (local disk only — no S3) ----------------------------------
FILE_STORAGE_PATH=/data/uploads
# Rejected above this size. On Windows, running the web app directly (outside
# Docker) resolves FILE_STORAGE_PATH relative to the current drive root, so
# prefer a relative path like ./data/uploads for that case.
MAX_UPLOAD_SIZE_MB=25

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development

# NOTE: this directory is not yet a git repository. This file is checked in
# ahead of time so that when `git init` eventually runs, secrets and build
# artifacts are ignored from the very first commit.

# dependencies
node_modules/

# next.js
.next/
out/

# production builds
build/
dist/

# environment files (secrets) — .env must never be committed
.env
.env.local
.env.*.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# misc
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# prisma generated client lives in node_modules; nothing extra to ignore here

# local file storage (uploaded documents live on local disk, never in git)
/storage/
/data/
